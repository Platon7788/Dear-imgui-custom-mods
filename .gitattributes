# Normalize line endings across the repo. Stops Git emitting the
# "LF will be replaced by CRLF the next time Git touches it" warning
# on Windows and guarantees identical checksums on Linux/macOS/Windows.

* text=auto eol=lf

# Lock platform-specific scripts to their native ending.
*.ps1  text eol=crlf
*.cmd  text eol=crlf
*.bat  text eol=crlf
*.sh   text eol=lf

# Binary assets — never let Git try to diff/normalize these.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.ttf  binary
*.otf  binary
*.woff binary
*.woff2 binary
*.wasm binary

# Explicit text for everything you'd ever diff.
*.rs   text diff=rust
*.toml text
*.md   text
*.yml  text
*.yaml text
*.json text
